{
  "name": "admate-lens",
  "version": "0.1.0",
  "private": true,
  "description": "AdMate Lens — 광고 게재면 캡처 자동화",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "check:abort-registry": "node scripts/check-capture-abort-registry.mjs",
    "check:surface-registry": "node scripts/check-surface-registry.mjs",
    "check:capture-metadata": "node scripts/check-capture-output-metadata.mjs scripts/fixtures/capture-metadata-smoke.json",
    "check:capture-batch-guards": "node scripts/check-capture-batch-guards.mjs",
    "check:capture-dimensions": "node scripts/check-capture-dimensions.mjs",
    "check:fixture-contracts": "node scripts/check-fixture-contracts.mjs",
    "check:golden-manifest": "node scripts/check-golden-manifest.mjs",
    "check:golden-metadata": "node scripts/check-golden-metadata.mjs",
    "check:golden-dimensions": "node scripts/check-golden-dimensions.mjs",
    "check:golden-pixels": "node scripts/check-golden-pixels.mjs",
    "harness:report": "node scripts/report-harness.mjs",
    "verify:offline-smoke": "npm run check:abort-registry && npm run check:capture-batch-guards && npm run verify:harness",
    "verify:harness": "npm run check:surface-registry && npm run check:capture-metadata && npm run check:fixture-contracts",
    "verify:golden": "npm run check:golden-manifest && npm run check:golden-metadata && npm run check:golden-dimensions && npm run check:golden-pixels"
  },
  "dependencies": {
    "@sparticuz/chromium-min": "^143.0.4",
    "@supabase/supabase-js": "^2.95.3",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "next": "^16.1.6",
    "puppeteer-core": "^24.37.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "eslint": "^10.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18"
  }
}
