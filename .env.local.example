# Supabase
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# 캡처 엔진
IS_LOCAL=true
# 로컬 UI/Auth 확인 전용. production에서는 코드가 무시합니다.
LENS_LOCAL_AUTH_BYPASS=false

# YouTube Data API v3 — 인피드 홈 합성 그리드가 “인기 차트” 메타로 채워지도록 할 때 설정
# (Google Cloud에서 API 키 발급 후 값만 넣으면 됨. 비우면 Invidious → oEmbed 순으로 폴백)
# YOUTUBE_DATA_API_KEY=
# 선택: 인기 차트 지역(2글자). 기본 KR
# YOUTUBE_TRENDING_REGION=KR
# 인피드 홈 합성 그리드: 실제 영상 카드 순서를 캡처마다 섞음(기본 on). 고정 순서가 필요하면 0
# YOUTUBE_INFEED_SYNTHETIC_SHUFFLE=1
# Data API 사용 시: 인기 차트에 search.list(KR 뉴스·예능 등)로 풀 보강·chart 실패 시 검색 폴백 (기본 on, 할당량 절약 시 0)
# YOUTUBE_INFEED_SYNTHETIC_SEARCH_ENRICH=1

# 프록시 (선택)
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
